venv_mlops/

# Virtual environments
venv/
ENV/
.venv/

# Python cache
__pycache__/
*.py[cod]
*.so

# ML artifacts (generated by pipeline - tracked by DVC)
# NOTE: models/ and artifacts/ are NOT ignored so Docker can copy them
mlruns/

# DVC cache
.dvc/cache/
.dvc/tmp/

# Data (intermediate outputs tracked by DVC)
data/validated/*.csv
data/processed/*.csv

# OS
.DS_Store
Thumbs.db

# IDE
.vscode/settings.json
.idea/

# Logs
*.log

# Reports (keep metrics.json, ignore large report files)
reports/*.txt
